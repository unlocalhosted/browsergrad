{
  "name": "browsergrad",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace root for the @unlocalhosted/browsergrad-* library family. Not published — install individual packages from npm.",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "validate:prd": "node scripts/validate-research-gated-prd.mjs",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/browsergrad.git"
  },
  "license": "MIT",
  "author": "unlocalhosted"
}
