{
  "id": "cs149gpt",
  "version": "0.1.0",
  "requires_browsergrad": "^0.1.0",
  "metadata": {
    "title": "CS149GPT",
    "course": "Stanford CS149: Parallel Computing",
    "source_url": "https://github.com/stanford-cs149/cs149gpt",
    "lecture_urls": [],
    "tags": ["parallel-computing", "attention", "cpp", "ispc", "nanogpt"]
  },
  "runtime_packages": ["numpy", "pytest"],
  "files": {
    "root": "/assignments/cs149gpt",
    "rubric_path": "rubric.py",
    "starter_path": "starter",
    "reference_path": "reference.py",
    "fixtures_path": "fixtures"
  },
  "timeouts": {
    "setup_ms": 10000,
    "test_ms": 45000,
    "worker_ms": 90000
  },
  "allowed_tests": [
    "naive_attention_correctness",
    "blocked_matmul_attention_correctness",
    "fused_attention_correctness",
    "flash_attention_correctness",
    "attention_performance_smoke"
  ],
  "oracles": [
    {
      "name": "_bg_attention_math",
      "js_module": "/assignments/cs149gpt/oracles/attention.js",
      "export_name": "oracle"
    }
  ],
  "gates": [
    {
      "name": "attention_optimization_browser_path",
      "kind": "capability",
      "options": {
        "requires": ["attention-oracle", "simd-simulator", "performance-rubric"],
        "any_of": [["torch-compat"], ["browser-cpp-simulator"], ["native-cpp-external"]],
        "message": "CS149GPT first slice should verify attention math and memory behavior before native C++ extension execution."
      }
    }
  ],
  "datasets": []
}
