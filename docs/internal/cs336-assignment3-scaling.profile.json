{
  "id": "cs336-assignment3-scaling",
  "version": "0.1.0",
  "requires_browsergrad": "^0.1.0",
  "metadata": {
    "title": "Stanford CS336 Assignment 3: Scaling",
    "course": "Stanford CS336: Language Modeling from Scratch",
    "source_url": "https://github.com/stanford-cs336/assignment3-scaling",
    "lecture_urls": ["https://cs336.stanford.edu/"],
    "tags": ["language-modeling", "scaling-laws", "hosted-api", "scheduler"]
  },
  "runtime_packages": ["numpy", "pytest", "requests"],
  "files": {
    "root": "/assignments/cs336-assignment3-scaling",
    "rubric_path": "rubric.py",
    "starter_path": "cs336_scaling",
    "reference_path": "reference.py",
    "fixtures_path": "fixtures"
  },
  "timeouts": {
    "setup_ms": 10000,
    "test_ms": 30000,
    "worker_ms": 60000
  },
  "allowed_tests": [
    "test_dashboard_serves_html",
    "test_budget",
    "test_submit_jobs",
    "test_submit_rejects_duplicate_training_config",
    "test_final_submission_accepts_training_config_and_predicted_loss",
    "test_select_experiments_for_dispatch_orders_by_running_count_then_queue_time",
    "test_select_experiments_for_dispatch_counts_running_jobs_without_capacity"
  ],
  "oracles": [
    {
      "name": "_bg_scaling_api",
      "js_module": "/assignments/cs336-assignment3-scaling/oracles/scaling-api.js",
      "export_name": "oracle"
    }
  ],
  "gates": [
    {
      "name": "scaling_api_browser_slice",
      "kind": "capability",
      "options": {
        "requires": ["http-client", "hosted-api-mock", "server-fixture"],
        "any_of": [["pyodide"], ["external-server"]],
        "message": "CS336 A3 first slice should use a deterministic hosted API mock or an explicit external server."
      }
    },
    {
      "name": "jax_training_external_only",
      "kind": "capability",
      "options": {
        "any_of": [["jax-external"], ["hosted-api-mock"]],
        "message": "Full JAX/Modal training is external; browser labs should start from API and scheduler fixtures."
      }
    },
    {
      "name": "student_code_timeout",
      "kind": "timeout",
      "options": {
        "timeout_ms": 30000
      }
    }
  ],
  "datasets": []
}
