{
  "name": "@unlocalhosted/browsergrad-compiler",
  "version": "0.1.0",
  "description": "CUDA-lite to BrowserGrad Kernel IR compiler with WGSL/WebGPU and CPU-reference execution.",
  "type": "module",
  "license": "MIT",
  "author": "unlocalhosted",
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/browsergrad.git",
    "directory": "packages/browsergrad-compiler"
  },
  "homepage": "https://github.com/unlocalhosted/browsergrad/tree/main/packages/browsergrad-compiler#readme",
  "bugs": {
    "url": "https://github.com/unlocalhosted/browsergrad/issues"
  },
  "keywords": [
    "webgpu",
    "wgsl",
    "cuda",
    "compiler",
    "gpu",
    "browser"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "bench": "pnpm run build && node ../../scripts/benchmark-cuda-lite-compiler.mjs",
    "bench:browser": "pnpm run build && node ../../scripts/benchmark-cuda-lite-webgpu.mjs",
    "e2e:webgpu": "pnpm run build && node ../../scripts/e2e-cuda-lite-webgpu.mjs",
    "audit:corpus": "pnpm run build && node ../../scripts/audit-cuda-lite-corpus.mjs",
    "audit:cuda-120": "pnpm run build && node ../../scripts/audit-cuda-lite-corpus.mjs /tmp/CUDA-120-DAYS--CHALLENGE --expect-total 240 --expect-ok-min 225 --expect-webgpu-min 235 --expect-reference-only-max 5 --expect-hard-fail-max 0",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:open": "vitest --config vitest.browser.config.ts --watch --browser.headless=false",
    "lint": "oxlint src",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@unlocalhosted/browsergrad-kernels": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@webgpu/types": "^0.1.50",
    "oxlint": "^1.0.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
