{
  "name": "@unlocalhosted/browsergrad-compiler",
  "version": "0.1.0",
  "description": "CUDA-lite to BrowserGrad Kernel IR compiler with WGSL/WebGPU and CPU-reference execution.",
  "type": "module",
  "license": "MIT",
  "author": "unlocalhosted",
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/browsergrad.git",
    "directory": "packages/browsergrad-compiler"
  },
  "homepage": "https://github.com/unlocalhosted/browsergrad/tree/main/packages/browsergrad-compiler#readme",
  "bugs": {
    "url": "https://github.com/unlocalhosted/browsergrad/issues"
  },
  "keywords": [
    "webgpu",
    "wgsl",
    "cuda",
    "compiler",
    "gpu",
    "browser"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:wgsl-modules": "vitest run tests/wgsl_modules.test.ts",
    "test:synthetic-input": "pnpm --dir ../.. --filter @unlocalhosted/browsergrad-kernels run build && pnpm run build && pnpm run test:synthetic-input:run",
    "test:synthetic-input:run": "node ../../scripts/test-cuda-lite-synthetic-input.mjs",
    "test:source-normalizer": "node ../../scripts/test-cuda-lite-source-normalizer.mjs",
    "test:webgpu-fixtures": "node ../../scripts/test-cuda-lite-webgpu-fixtures.mjs",
    "test:test-scope": "node ../../scripts/test-cuda-lite-test-scope.mjs",
    "test:bugbash-status": "node ../../scripts/test-cuda-lite-bugbash-status.mjs",
    "test:verify-real-world-cli": "node ../../scripts/test-verify-real-world-cuda-cli.mjs",
    "test:tool-lock": "node ../../scripts/test-cuda-lite-tool-lock.mjs",
    "test:audit-corpus": "pnpm --dir ../.. --filter @unlocalhosted/browsergrad-kernels run build && pnpm run build && pnpm run test:audit-corpus:run",
    "test:audit-corpus:run": "node ../../scripts/test-cuda-lite-corpus-audit.mjs",
    "bench": "node ../../scripts/run-cuda-lite-tool.mjs bench",
    "bench:browser": "node ../../scripts/run-cuda-lite-tool.mjs bench:browser",
    "e2e:webgpu": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu",
    "e2e:webgpu:case": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --summary-only --fail-fast --case-timeout-ms 10000",
    "e2e:webgpu:warm-case": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --summary-only --fail-fast --repeat 3 --case-timeout-ms 10000",
    "e2e:webgpu:hot-case": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --summary-only --fail-fast --warmup 1 --repeat 3 --case-timeout-ms 10000",
    "e2e:webgpu:hot-case:gate": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --summary-only --fail-fast --repeat 3 --expect-warm-speedup-min 1.2 --case-timeout-ms 10000",
    "e2e:webgpu:corpus-hot": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --summary-only --fail-fast --cases corpus:cuda-samples:histogram64Kernel,corpus:cuda-samples:scalarProdGPU --repeat 2 --expect-warm-speedup-min 10 --case-timeout-ms 10000",
    "e2e:webgpu:compile": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu -- --require-webgpu --forbid-skips --summary-only --compile-only --auto-corpus-smoke-only --auto-corpus-smoke-profile fast --auto-corpus-smoke-cache --auto-corpus-smoke-limit 32 --case-timeout-ms 10000",
    "e2e:webgpu:smoke": "node ../../scripts/run-cuda-lite-webgpu-smoke.mjs",
    "e2e:webgpu:fast": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu -- --require-webgpu --forbid-skips --summary-only --auto-corpus-smoke-only --auto-corpus-smoke-profile fast --auto-corpus-smoke-cache --auto-corpus-smoke-limit 32 --case-timeout-ms 30000",
    "e2e:webgpu:fixtures": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu --skip-build -- --require-webgpu --forbid-skips --require-corpus-fixtures --summary-only --corpus-fixtures-only --case-timeout-ms 30000",
    "e2e:webgpu:last-failures": "node ../../scripts/run-cuda-lite-last-failures.mjs",
    "bugbash:status": "node ../../scripts/cuda-lite-bugbash-status.mjs",
    "bugbash:status:json": "node ../../scripts/cuda-lite-bugbash-status.mjs --json",
    "verify:changed:plan": "node ../../scripts/cuda-lite-test-scope.mjs",
    "verify:changed": "node ../../scripts/cuda-lite-test-scope.mjs --run",
    "verify:changed:compile": "node ../../scripts/cuda-lite-test-scope.mjs --run --include-compile-corpus",
    "verify:changed:fast": "node ../../scripts/cuda-lite-test-scope.mjs --run --include-fast-corpus",
    "e2e:webgpu:dist": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu -- --forbid-skips --bundle dist",
    "e2e:webgpu:corpus": "node ../../scripts/run-cuda-lite-tool.mjs e2e:webgpu -- --forbid-skips --require-corpus-fixtures",
    "audit:corpus": "node ../../scripts/run-cuda-lite-tool.mjs audit:corpus",
    "audit:real-world-cuda": "node ../../scripts/run-cuda-lite-tool.mjs audit:real-world-cuda",
    "verify:real-world-cuda": "node ../../scripts/run-cuda-lite-tool.mjs verify:real-world-cuda",
    "verify:compiler": "pnpm --dir ../.. --filter @unlocalhosted/browsergrad-kernels run build && pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:synthetic-input:run && pnpm run test:source-normalizer && pnpm run test:webgpu-fixtures && pnpm run test:test-scope && pnpm run test:bugbash-status && pnpm run test:verify-real-world-cli && pnpm run test:tool-lock && pnpm run test:audit-corpus:run",
    "audit:cuda-120": "node ../../scripts/run-cuda-lite-tool.mjs audit:cuda-120",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:open": "vitest --config vitest.browser.config.ts --watch --browser.headless=false",
    "lint": "oxlint src",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run verify:compiler"
  },
  "dependencies": {
    "@unlocalhosted/browsergrad-kernels": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@webgpu/types": "^0.1.50",
    "oxlint": "^1.0.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
