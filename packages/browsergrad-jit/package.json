{
  "name": "@unlocalhosted/browsergrad-jit",
  "version": "0.1.0-pre.1",
  "description": "PyTorch-shaped Python library that traces ops into a UOp IR and realizes through NumPy. The JIT epoch successor to browsergrad-grad — same API surface, lazy by default, designed for downstream fusion / WGSL / WebNN passes. Educational source code, MIT-licensed.",
  "type": "module",
  "license": "MIT",
  "author": "unlocalhosted",
  "repository": {
    "type": "git",
    "url": "https://github.com/unlocalhosted/browsergrad.git",
    "directory": "packages/browsergrad-jit"
  },
  "homepage": "https://github.com/unlocalhosted/browsergrad/tree/main/packages/browsergrad-jit#readme",
  "bugs": {
    "url": "https://github.com/unlocalhosted/browsergrad/issues"
  },
  "keywords": [
    "tensor",
    "autograd",
    "jit",
    "tracer",
    "ir",
    "pyodide",
    "education",
    "machine-learning",
    "browser",
    "numpy"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./source": {
      "types": "./dist/python/index.d.ts",
      "import": "./dist/python/index.js"
    },
    "./node-adapter": {
      "types": "./dist/node-adapter.d.ts",
      "import": "./dist/node-adapter.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "codegen": "node scripts/build-python-sources.mjs",
    "build": "pnpm codegen && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "oxlint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@webgpu/types": "^0.1.50",
    "oxlint": "^1.0.0",
    "pyodide": "^0.26.4",
    "typescript": "~6.0.0",
    "vitest": "^4.0.0"
  },
  "optionalPeerDependencies": {
    "pyodide": "^0.26.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
